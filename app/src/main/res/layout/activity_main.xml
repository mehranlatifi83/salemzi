<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground"
    android:layoutDirection="rtl">

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="44dp"
            android:paddingBottom="12dp">

            <TextView
                android:text="@string/app_name"
                android:textSize="28sp"
                android:textColor="@color/colorOnSurface"
                android:fontFamily="sans-serif-medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/text_date"
                android:textSize="13sp"
                android:textColor="@color/colorOnSurfaceVariant"
                android:layout_marginTop="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Main area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Sleep Circle -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_circle"
                android:layout_width="200dp"
                android:layout_height="200dp"
                app:cardCornerRadius="100dp"
                app:cardElevation="16dp"
                app:cardBackgroundColor="@color/colorSurface"
                app:strokeWidth="2dp"
                app:strokeColor="@color/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/icon_sleep"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:src="@drawable/ic_moon"
                        android:tint="@color/colorOnSurfaceVariant"/>

                    <TextView
                        android:text="@string/sleep_mode"
                        android:textSize="15sp"
                        android:textColor="@color/colorOnSurface"
                        android:layout_marginTop="12dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/text_status"
                        android:text="@string/status_inactive"
                        android:textSize="13sp"
                        android:textColor="@color/colorOnSurfaceVariant"
                        android:layout_marginTop="3dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Toggle Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_toggle"
                android:layout_width="220dp"
                android:layout_height="52dp"
                android:layout_marginTop="32dp"
                android:text="@string/btn_enable_sleep"
                android:textSize="14sp"
                app:cornerRadius="26dp"/>

            <!-- Overlay permission row -->
            <LinearLayout
                android:id="@+id/row_overlay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp">

                <TextView
                    android:text="@string/overlay_label"
                    android:textSize="12sp"
                    android:textColor="@color/colorOnSurfaceVariant"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/text_overlay_status"
                    android:textSize="12sp"
                    android:textColor="@color/colorPrimary"
                    android:layout_marginStart="6dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <!-- Lock mode selector -->
            <LinearLayout
                android:id="@+id/row_lock_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp">

                <TextView
                    android:text="@string/lock_mode_label"
                    android:textSize="12sp"
                    android:textColor="@color/colorOnSurfaceVariant"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/text_lock_mode"
                    android:textSize="12sp"
                    android:textColor="@color/colorPrimary"
                    android:layout_marginStart="6dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <!-- Schedule Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_schedule"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/colorSurface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/colorDivider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Header row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="4dp">

                        <TextView
                            android:text="برنامه خواب"
                            android:textSize="13sp"
                            android:textColor="@color/colorOnSurfaceVariant"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"/>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_schedule"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false"/>
                    </LinearLayout>

                    <!-- Times row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="16dp"
                        android:paddingTop="8dp">

                        <!-- Sleep time -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_moon"
                                android:tint="@color/colorOnSurfaceVariant"/>

                            <TextView
                                android:id="@+id/text_sleep_time"
                                android:text="@string/schedule_not_set"
                                android:textSize="20sp"
                                android:textColor="@color/colorOnSurface"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="6dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:text="@string/label_sleep_time"
                                android:textSize="11sp"
                                android:textColor="@color/colorOnSurfaceVariant"
                                android:layout_marginTop="2dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center_vertical"
                            android:background="@color/colorDivider"/>

                        <!-- Wake time -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_sun"
                                android:tint="@color/colorOnSurfaceVariant"/>

                            <TextView
                                android:id="@+id/text_wake_time"
                                android:text="@string/schedule_not_set"
                                android:textSize="20sp"
                                android:textColor="@color/colorOnSurface"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="6dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:text="@string/label_wake_time"
                                android:textSize="11sp"
                                android:textColor="@color/colorOnSurfaceVariant"
                                android:layout_marginTop="2dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/text_schedule_hint"
                android:text="@string/tap_to_set"
                android:textSize="12sp"
                android:textColor="@color/colorOnSurfaceVariant"
                android:layout_marginTop="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>
    </LinearLayout>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorSurface"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/bottom_nav_selector"
        app:itemTextColor="@color/bottom_nav_selector"/>

</LinearLayout>
